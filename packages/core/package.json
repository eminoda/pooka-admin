{
  "name": "@pooka/core",
  "version": "0.0.0",
  "private": true,
  "description": "Pooka core — ProTable, ProForm, JSON schema renderer",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ui-kit/table": {
      "types": "./dist/ui-kit/table/index.d.ts",
      "import": "./dist/ui-kit/table/index.js"
    },
    "./ui-kit/form": {
      "types": "./dist/ui-kit/form/index.d.ts",
      "import": "./dist/ui-kit/form/index.js"
    },
    "./renderer": {
      "types": "./dist/renderer/index.d.ts",
      "import": "./dist/renderer/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@tanstack/vue-query": "^5.90.5",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tanstack/vue-query": "^5.90.5",
    "@pooka/config": "workspace:*",
    "eslint": "^9.23.0",
    "typescript": "^5.8.2",
    "vue": "^3.5.13"
  }
}
