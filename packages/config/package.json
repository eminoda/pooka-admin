{
  "name": "@pooka/config",
  "version": "0.0.0",
  "private": true,
  "description": "Shared ESLint, Prettier, TypeScript base, and future UnoCSS / Tailwind presets for Pooka Admin",
  "type": "module",
  "exports": {
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./eslint": "./eslint.config.js",
    "./prettier": "./prettier.config.js"
  },
  "scripts": {
    "build": "node -e \"console.log('@pooka/config: no build output')\"",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vue-eslint-parser": "^10.1.1"
  }
}
