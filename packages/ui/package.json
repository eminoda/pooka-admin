{
  "name": "@pooka/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Pooka base UI — shadcn-vue (vendored) + UnoCSS integration (phase 1: config only)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": ["dist", "src/styles.css", "components.json", "uno.config.ts"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@pooka/config": "workspace:*",
    "eslint": "^9.23.0",
    "typescript": "^5.8.2",
    "vue": "^3.5.13"
  }
}
