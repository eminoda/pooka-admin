{
  "name": "@pooka/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Pooka base UI — shadcn-vue (vendored) + UnoCSS integration (phase 1: config only)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css",
    "./preset": {
      "types": "./dist/preset.d.ts",
      "import": "./dist/preset.js"
    },
    "./component-map.json": "./component-map.json"
  },
  "files": [
    "dist",
    "src/styles.css",
    "components.json",
    "component-map.json",
    "uno.config.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@iconify-json/ant-design": "^1.2.5",
    "@unocss/preset-icons": "66.5.4",
    "@unocss/preset-wind4": "66.5.4",
    "unocss": "66.5.4",
    "unocss-preset-animations": "^1.3.0",
    "unocss-preset-antd": "^0.0.1",
    "unocss-preset-element-plus": "^0.2.2",
    "unocss-preset-shadcn": "^1.0.1"
  },
  "peerDependencies": {
    "@pooka/core": "workspace:*",
    "@tanstack/vue-table": "^8.21.3",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@pooka/core": "workspace:*",
    "@tanstack/vue-table": "^8.21.3",
    "eslint": "^9.23.0",
    "typescript": "^5.8.2",
    "vue": "^3.5.13"
  }
}
