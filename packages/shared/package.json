{
  "name": "@pooka/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared utils, composables, and types for Pooka Admin",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@pooka/config": "workspace:*",
    "eslint": "^9.23.0",
    "typescript": "^5.8.2",
    "vue": "^3.5.13"
  }
}
